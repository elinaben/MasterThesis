@article{tengProBDNFInducesNeuronal2005,
  title = {{{ProBDNF}} Induces Neuronal Apoptosis via Activation of a Receptor Complex of {{p75NTR}} and Sortilin},
  author = {Teng, Henry K. and Teng, Kenneth K. and Lee, Ramee and Wright, Saundrene and Tevar, Seema and Almeida, Ramiro D. and Kermani, Pouneh and Torkin, Risa and Chen, Zhe-Yu and Lee, Francis S. and Kraemer, Rosemary T. and Nykjaer, Anders and Hempstead, Barbara L.},
  year = 2005,
  month = jun,
  journal = {The Journal of Neuroscience: The Official Journal of the Society for Neuroscience},
  volume = {25},
  number = {22},
  pages = {5455--5463},
  issn = {1529-2401},
  doi = {10.1523/JNEUROSCI.5123-04.2005},
  abstract = {Brain-derived neurotrophic factor (BDNF) is best characterized for critical roles in neuronal survival, differentiation, and synaptic modulation mediated by the TrkB receptor tyrosine kinase. Developmentally regulated death signaling by BDNF has also been demonstrated via activation of p75NTR. Because recent studies suggest that proNGF, the precursor form of NGF, is more active than mature NGF in inducing apoptosis after binding to p75NTR and a coreceptor, sortilin, we asked whether the precursor of BDNF (proBDNF) is also a proapoptotic ligand in the nervous system. proBDNF is secreted by cultured neurons, and recombinant proBDNF binds to sortilin. In sympathetic neurons coexpressing sortilin and p75NTR, we found that proBDNF is an apoptotic ligand that induces death at subnanomolar concentrations. In contrast, mature BDNF, but not proBDNF, is effective in inducing TrkB phosphorylation. proBDNF effects are dependent on cellular coexpression of both p75NTR and sortilin, because neurons deficient in p75NTR are resistant to proBDNF-induced apoptosis, and competitive antagonists of sortilin block sympathetic neuron death. Moreover, addition of preformed complexes of soluble sortilin and proBDNF failed to induce apoptosis of cells coexpressing both sortilin and p75NTR, suggesting that interaction of proBDNF with both receptors on the cell surface is required to initiate cell death. Together with our past findings, these data suggest that the neurotrophin family is capable of modulating diverse biological processes via differential processing of the proneurotrophins.},
  langid = {english},
  pmcid = {PMC6724992},
  pmid = {15930396},
  keywords = {Adaptor Proteins Vesicular Transport,Animals,Apoptosis,Brain,Brain-Derived Neurotrophic Factor,Cell Line,Humans,Ligands,Membrane Glycoproteins,Mice,Mice Knockout,Nerve Tissue Proteins,Neurons,Phosphorylation,Protein Precursors,Rats,Rats Sprague-Dawley,Receptor Nerve Growth Factor,Receptor trkB,Receptors Growth Factor,Receptors Nerve Growth Factor,Schwann Cells,Sortilin,Superior Cervical Ganglion},
  file = {C:\Users\arikn\Zotero\storage\I6XCNH6I\Teng et al. - 2005 - ProBDNF induces neuronal apoptosis via activation of a receptor complex of p75NTR and sortilin.pdf}
}
